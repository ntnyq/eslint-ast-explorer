{
  "name": "eslint-ast-explorer",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "description": "ESLint AST Explorer.",
  "keywords": [],
  "repository": "ntnyq/eslint-ast-explorer",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "generate": "nuxt generate",
    "lint": "eslint",
    "postinstall": "nuxt prepare",
    "prepare": "husky",
    "preview": "nuxt preview",
    "release": "run-s release:check release:version",
    "release:check": "run-s format:check lint typecheck",
    "release:version": "bumpp",
    "typecheck": "nuxt typecheck"
  },
  "dependencies": {
    "@babel/eslint-parser": "^8.0.1",
    "@babel/parser": "^8.0.0",
    "@lucide/vue": "^1.22.0",
    "@ntnyq/utils": "^0.16.0",
    "@shikijs/core": "^4.3.0",
    "@shikijs/engine-javascript": "^4.3.0",
    "@shikijs/langs": "^4.3.0",
    "@shikijs/monaco": "^4.3.0",
    "@shikijs/themes": "^4.3.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/esprima": "^4.0.6",
    "@typescript-eslint/parser": "^8.62.1",
    "@vueuse/core": "^14.3.0",
    "astro-eslint-parser": "^2.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.21",
    "eslint-mdx": "^3.8.1",
    "espree": "^11.2.0",
    "esprima": "^4.0.1",
    "json-to-ast": "^2.1.0",
    "json5": "^2.2.3",
    "jsonc-eslint-parser": "^3.1.0",
    "monaco-editor": "^0.55.1",
    "reka-ui": "^2.10.1",
    "svelte": "^5.56.4",
    "svelte-eslint-parser": "^1.8.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "toml-eslint-parser": "^1.0.3",
    "tw-animate-css": "^1.4.0",
    "vue-eslint-parser": "^10.4.1",
    "yaml-eslint-parser": "^2.0.0"
  },
  "devDependencies": {
    "@ntnyq/eslint-config": "^6.1.5",
    "@rolldown/plugin-node-polyfills": "^1.0.3",
    "@types/node": "^26.0.1",
    "@vueuse/nuxt": "^14.3.0",
    "bumpp": "^11.1.0",
    "consola": "^3.4.2",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "nano-staged": "^1.0.2",
    "npm-run-all2": "^9.0.2",
    "nuxt": "^4.4.8",
    "nuxt-monaco-editor": "^1.4.0",
    "nuxt-umami": "^3.2.1",
    "oxfmt": "^0.57.0",
    "pathe": "^2.0.3",
    "rolldown": "^1.1.3",
    "shadcn-nuxt": "^2.7.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "unenv": "^1.10.0",
    "unplugin-replace": "^0.9.0",
    "vite": "^8.1.0",
    "vue-tsc": "^3.3.5"
  },
  "nano-staged": {
    "*.{js,ts,mjs,tsx,vue,md,yml,yaml,toml,json}": "eslint --fix --no-error-on-unmatched-pattern",
    "*": "oxfmt --no-error-on-unmatched-pattern"
  }
}
